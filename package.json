{
  "name": "@dooph-software/design-system",
  "version": "1.0.2",
  "description": "dooph standard design system component library",
  "type": "module",
  "license": "MIT",
  "private": false,
  "repository": {
    "type": "git",
    "url": "https://github.com/dooph-software/dooph.-design-system.git"
  },
  "homepage": "https://github.com/dooph-software/dooph.-design-system#readme",
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  },
  "bin": {
    "init-skills": "./bin/init.mjs"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./styles.css": "./dist/styles.css"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": [
    "./dist/styles.css"
  ],
  "files": [
    "dist",
    "skills",
    "bin"
  ],
  "scripts": {
    "generate-icon-exports": "node scripts/generate-icon-exports.mjs",
    "sync-tokens": "node scripts/sync-theme.mjs",
    "build:js": "tsup",
    "build:css": "tailwindcss -i src/styles/index.css -o dist/styles.css",
    "build": "npm run generate-icon-exports && npm run sync-tokens && npm run build:js",
    "build:watch": "tsup --watch",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build",
    "prep-release": "npm version patch && npm run build"
  },
  "peerDependencies": {
    "react": ">=19",
    "react-dom": ">=19"
  },
  "devDependencies": {
    "@storybook/addon-docs": "^10.3.6",
    "@storybook/react-vite": "^10.3.6",
    "@tailwindcss/cli": "^4.2.4",
    "@tailwindcss/vite": "^4.2.4",
    "@types/node": "^22.19.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "storybook": "^10.3.6",
    "tailwindcss": "^4.2.4",
    "tailwindcss-animate": "^1.0.7",
    "tsup": "^8.5.1",
    "typescript": "~5.9.3",
    "vite": "^6.4.2"
  },
  "dependencies": {
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toast": "^1.2.15",
    "@radix-ui/react-toggle-group": "^1.1.11",
    "@radix-ui/react-tooltip": "^1.2.8",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "tailwind-merge": "^3.5.0"
  },
  "optionalDependencies": {
    "@parcel/watcher-win32-arm64": "^2.5.6"
  }
}
